{
  "name": "@hapticjs/gamepad",
  "version": "0.2.0",
  "description": "Gamepad haptics adapter for Feelback — dual motor support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@hapticjs/core": "workspace:*"
  },
  "devDependencies": {
    "@hapticjs/core": "workspace:*"
  },
  "keywords": [
    "haptic",
    "haptics",
    "tap",
    "gamepad",
    "controller",
    "vibration",
    "rumble",
    "dual-motor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thirumaleshp/Feelback.git"
  },
  "license": "MIT"
}
