{
  "name": "@hapticjs/core",
  "version": "0.4.0",
  "description": "Universal Haptics Engine — feel the web",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./presets": {
      "import": {
        "types": "./dist/presets/index.d.ts",
        "default": "./dist/presets/index.js"
      },
      "require": {
        "types": "./dist/presets/index.d.cts",
        "default": "./dist/presets/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "haptics",
    "vibration",
    "tactile",
    "feedback",
    "touch",
    "haptic-feedback",
    "vibrate",
    "mobile"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aspect-js/feelback",
    "directory": "packages/core"
  }
}
