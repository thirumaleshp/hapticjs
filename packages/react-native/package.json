{
  "name": "@hapticjs/react-native",
  "version": "0.1.0",
  "description": "React Native adapter for Feelback haptic engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.60.0",
    "@hapticjs/core": "workspace:*",
    "react-native-haptic-feedback": ">=2.0.0",
    "expo-haptics": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-haptic-feedback": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@hapticjs/core": "workspace:*"
  },
  "keywords": [
    "haptic",
    "haptics",
    "tap",
    "react-native",
    "haptic-feedback",
    "vibration",
    "expo"
  ],
  "repository": {"type": "git", "url": "https://github.com/thirumaleshp/Feelback.git"},
  "license": "MIT"
}
