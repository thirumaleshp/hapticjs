{
  "name": "@vibejs/vue",
  "version": "0.1.0",
  "description": "Vue composables and directives for Feelback haptic engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "@vibejs/core": "workspace:*"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "@vibejs/core": "workspace:*"
  },
  "keywords": ["haptics", "vue", "composables", "directives", "vibration"],
  "license": "MIT"
}
