{
  "name": "@hapticjs/svelte",
  "version": "0.1.1",
  "description": "Svelte actions and stores for Feelback haptic engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0",
    "@hapticjs/core": "workspace:*"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "@hapticjs/core": "workspace:*"
  },
  "keywords": ["haptic", "haptics", "tap", "svelte", "actions", "vibration"],
  "repository": {"type": "git", "url": "https://github.com/thirumaleshp/Feelback.git"},
  "license": "MIT"
}
