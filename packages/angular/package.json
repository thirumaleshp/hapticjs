{
  "name": "@hapticjs/angular",
  "version": "0.1.0",
  "description": "Angular service for Haptic.js haptic engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "@hapticjs/core": "workspace:*"
  },
  "devDependencies": {
    "@hapticjs/core": "workspace:*"
  },
  "keywords": [
    "haptics",
    "angular",
    "service",
    "vibration",
    "haptic-feedback"
  ],
  "repository": {"type": "git", "url": "https://github.com/thirumaleshp/Feelback.git"},
  "license": "MIT"
}
